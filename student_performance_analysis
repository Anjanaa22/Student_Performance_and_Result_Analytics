        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "data = {\n",
        "    \"Name\": [\"Arun\", \"Bala\", \"Charan\", \"Divya\", \"Eswar\"],\n",
        "    \"Math\": [90, 45, 78, 88, 35],\n",
        "    \"Science\": [85, 40, 80, 92, 30],\n",
        "    \"English\": [88, 50, 70, 95, 25]\n",
        "}\n",
        "\n",
        "df = pd.DataFrame(data)\n",
        "\n",
        "df[\"Average\"] = (df[\"Math\"] + df[\"Science\"] + df[\"English\"]) / 3\n",
        "\n",
        "df[\"Result\"] = df[\"Average\"].apply(\n",
        "    lambda x: \"Pass\" if x >= 40 else \"Fail\"\n",
        ")\n",
        "\n",
        "def grade(avg):\n",
        "    if avg >= 90:\n",
        "        return \"A+\"\n",
        "    elif avg >= 75:\n",
        "        return \"A\"\n",
        "    elif avg >= 50:\n",
        "        return \"B\"\n",
        "    else:\n",
        "        return \"C\"\n",
        "\n",
        "df[\"Grade\"] = df[\"Average\"].apply(grade)\n",
        "\n",
        "# Outputs\n",
        "print(\"STUDENT PERFORMANCE REPORT\")\n",
        "print(\"=\"*50)\n",
        "\n",
        "print(\"\\nStudent Details:\")\n",
        "print(df)\n",
        "\n",
        "topper = df.loc[df[\"Average\"].idxmax()]\n",
        "print(\"\\nTopper:\")\n",
        "print(topper)\n",
        "\n",
        "weak_students = df[df[\"Average\"] < 40]\n",
        "print(\"\\nWeak Students:\")\n",
        "print(weak_students)\n",
        "\n",
        "subject_avg = df[[\"Math\", \"Science\", \"English\"]].mean()\n",
        "\n",
        "print(\"\\nSubject Average:\")\n",
        "print(subject_avg)\n",
        "\n",
        "# 3 Charts in One Row\n",
        "fig, axes = plt.subplots(1, 3, figsize=(15, 5))\n",
        "\n",
        "# Bar Chart\n",
        "subject_avg.plot(kind=\"bar\", ax=axes[0])\n",
        "axes[0].set_title(\"Bar Chart\")\n",
        "axes[0].set_xlabel(\"Subjects\")\n",
        "axes[0].set_ylabel(\"Average Marks\")\n",
        "\n",
        "# Line Chart\n",
        "subject_avg.plot(kind=\"line\", marker=\"o\", ax=axes[1])\n",
        "axes[1].set_title(\"Line Chart\")\n",
        "axes[1].set_xlabel(\"Subjects\")\n",
        "axes[1].set_ylabel(\"Average Marks\")\n",
        "\n",
        "# Pie Chart\n",
        "subject_avg.plot(kind=\"pie\", autopct=\"%1.1f%%\", ax=axes[2])\n",
        "axes[2].set_title(\"Pie Chart\")\n",
        "axes[2].set_ylabel(\"\")\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.show()"
